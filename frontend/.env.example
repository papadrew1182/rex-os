# Vite env vars for Rex OS frontend.
# Copy to .env.local for dev, set on Vercel for prod.

# Backend API base URL.
#   - Dev (with `npm run dev`): leave blank, the Vite proxy in vite.config.js
#     handles /api → http://localhost:9000
#   - Production (Vercel): set to the deployed Railway backend URL,
#     e.g. https://rex-os-backend-production.up.railway.app
VITE_API_URL=
