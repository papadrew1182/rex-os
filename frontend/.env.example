# Vite env vars for Rex OS frontend.
# Copy to .env.local for dev, set on Vercel for prod.

# Backend API base URL.
#   - Dev (with `npm run dev`): leave blank, the Vite proxy in vite.config.js
#     handles /api → http://localhost:9000
#   - Production (Vercel): set to the deployed Railway backend URL,
#     e.g. https://rex-os-backend-production.up.railway.app
VITE_API_URL=

# ── Playwright (optional) ────────────────────────────────────────────────
# Used by e2e/mobile-overflow.spec.js to log in before asserting layout.
# Keep these in .env.local (gitignored). Never commit a real password.
#
#   REX_E2E_URL        — where the tests should point (dev server OR deploy).
#                         Defaults to http://localhost:5173.
#   REX_E2E_EMAIL      — login email for authenticated pages.
#   REX_E2E_PASSWORD   — login password. If absent, the auth test is skipped
#                         (overflow checks on the login page still run).
REX_E2E_URL=
REX_E2E_EMAIL=
REX_E2E_PASSWORD=
